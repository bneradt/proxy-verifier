{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 3
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_INSTALL_BINDIR": "bin"
      }
    },
    {
      "name": "dev-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_INSTALL_PREFIX": "/usr/local"
      }
    },
    {
      "name": "dev-external-base",
      "hidden": true,
      "inherits": "dev-base",
      "cacheVariables": {
        "PV_BOOTSTRAP_DEPS": "OFF",
        "PV_DEPS_ROOT": "/opt/pv_libs"
      }
    },
    {
      "name": "dev-bootstrap-base",
      "hidden": true,
      "inherits": "dev-base",
      "cacheVariables": {
        "PV_BOOTSTRAP_DEPS": "ON"
      }
    },
    {
      "name": "portable-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS_RELEASE": "-O2 -DNDEBUG",
        "CMAKE_CXX_FLAGS_RELEASE": "-O2 -DNDEBUG",
        "CMAKE_INSTALL_PREFIX": "/tmp",
        "BUILD_PORTABLE": "ON",
        "PV_RELEASE_LAYOUT": "ON",
        "PV_STATIC_BUILD": "ON"
      }
    },
    {
      "name": "portable-external-base",
      "hidden": true,
      "inherits": "portable-base",
      "cacheVariables": {
        "PV_BOOTSTRAP_DEPS": "OFF",
        "PV_DEPS_ROOT": "/opt/pv_libs"
      }
    },
    {
      "name": "portable-bootstrap-base",
      "hidden": true,
      "inherits": "portable-base",
      "cacheVariables": {
        "PV_BOOTSTRAP_DEPS": "ON"
      }
    },
    {
      "name": "native-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS_RELEASE": "-O3 -DNDEBUG -march=native -mtune=native",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -DNDEBUG -march=native -mtune=native",
        "CMAKE_INSTALL_PREFIX": "/usr/local",
        "PV_STATIC_BUILD": "OFF"
      }
    },
    {
      "name": "native-external-base",
      "hidden": true,
      "inherits": "native-base",
      "cacheVariables": {
        "PV_BOOTSTRAP_DEPS": "OFF",
        "PV_DEPS_ROOT": "/opt/pv_libs"
      }
    },
    {
      "name": "native-bootstrap-base",
      "hidden": true,
      "inherits": "native-base",
      "cacheVariables": {
        "PV_BOOTSTRAP_DEPS": "ON"
      }
    },
    {
      "name": "dev-bootstrap",
      "inherits": "dev-bootstrap-base"
    },
    {
      "name": "dev-bootstrap-asan",
      "inherits": "dev-bootstrap",
      "cacheVariables": {
        "PV_ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "dev-external",
      "inherits": "dev-external-base"
    },
    {
      "name": "dev-external-asan",
      "inherits": "dev-external",
      "cacheVariables": {
        "PV_ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "portable-external",
      "inherits": "portable-external-base"
    },
    {
      "name": "portable-bootstrap",
      "inherits": "portable-bootstrap-base"
    },
    {
      "name": "native-external",
      "inherits": "native-external-base"
    },
    {
      "name": "native-bootstrap",
      "inherits": "native-bootstrap-base"
    }
  ],
  "buildPresets": [
    {
      "name": "dev-bootstrap",
      "configurePreset": "dev-bootstrap"
    },
    {
      "name": "dev-bootstrap-asan",
      "configurePreset": "dev-bootstrap-asan"
    },
    {
      "name": "dev-external",
      "configurePreset": "dev-external"
    },
    {
      "name": "dev-external-asan",
      "configurePreset": "dev-external-asan"
    },
    {
      "name": "portable-external",
      "configurePreset": "portable-external"
    },
    {
      "name": "portable-bootstrap",
      "configurePreset": "portable-bootstrap"
    },
    {
      "name": "native-external",
      "configurePreset": "native-external"
    },
    {
      "name": "native-bootstrap",
      "configurePreset": "native-bootstrap"
    }
  ],
  "testPresets": [
    {
      "name": "dev-bootstrap",
      "configurePreset": "dev-bootstrap",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-bootstrap-asan",
      "configurePreset": "dev-bootstrap-asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-external",
      "configurePreset": "dev-external",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-external-asan",
      "configurePreset": "dev-external-asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "portable-external",
      "configurePreset": "portable-external",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "portable-bootstrap",
      "configurePreset": "portable-bootstrap",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "native-external",
      "configurePreset": "native-external",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "native-bootstrap",
      "configurePreset": "native-bootstrap",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
