{
  "$schema": "https://github.com/apache/trafficserver/tree/master/tests/tools/lib/replay_schema.json",
  "title": "Traffic Server Replay File",
  "description": "Data for Traffic Server sessions and transactions. Licensed under Apache V2 https://www.apache.org/licenses/LICENSE-2.0",
  "type": "object",
  "properties": {
    "meta": {
      "description": "Metadata for the file.",
      "type": "object",
      "properties": {
        "version": {
          "description": "File format version.",
          "type": "string"
        }
      }
    },
    "sessions": {
      "description": "List of sessions",
      "type": "array",
      "items": {
        "title": "Session",
        "description": "Session data.",
        "type": "object",
        "required": [ "transactions" ],
        "properties": {
          "protocol": {
            "description": "The network protocol description of the inbound connection.",
            "$ref": "#/definitions/protocol"
          },
          "connect-time": {
            "description": "User Agent connection time.",
            "type": "number"
          },
          "transactions": {
            "description": "List of transactions",
            "type": "array",
            "items": {
              "description": "Transaction",
              "type": "object",
              "required": [ "client-request", "proxy-response" ],
              "properties": {
                "uuid": {
                  "description": "UUID to identify this specific transaction.",
                  "type": "string"
                },
                "start-time": {
                  "description": "Start time in epoch format",
                  "type": "number"
                },
                "client-request": {
                  "description": "Request sent by the inbound (downstream) connection.",
                  "$ref": "#/definitions/request"
                },
                "proxy-request": {
                  "description": "Request sent by the proxy.",
                  "$ref": "#/definitions/request"
                },
                "server-response": {
                  "description": "Response from the outbound (upstream) connection.",
                  "$ref": "#/definitions/response"
                },
                "proxy-response": {
                  "description": "Response sent by the proxy.",
                  "$ref": "#/definitions/response"
                }
              }
            }
          }
        }
      }
    }
  },

  "definitions": {
    "encoding": {
      "description": "Text encoding format.",
      "type": "string",
      "enum": ["plain", "uri", "esc_json"]
    },
    "content": {
      "description": "HTTP payload.",
      "anyOf" : [
        {
          "type": "object",
          "description": "Explicit payload.",
          "required": ["data"],
          "properties": {
            "encoding": {
              "description": "Content data encoding for JSON compatibility.",
              "$ref": "#/definitions/encoding"
            },
            "size": {
              "description": "Size of the payload in bytes. This must match the actual size of the 'data' field.",
              "type": "number"
            },
            "data": {
              "description": "Content data.",
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "description": "Synthesized payload (only size specified)",
          "required": ["size"],
          "properties": {
            "encoding": {
              "description": "Content data encoding for JSON compatibility.",
              "$ref": "#/definitions/encoding"
            },
            "size": {
              "description": "Size of the payload in bytes.",
              "type": "number"
            }
          }
        }
      ]
    },
    "protocol": {
      "description": "The characteristics of the lower level protocols.",
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "description": "The name of the protocol layer.",
                "type": "string",
                "enum": ["http", "tls", "proxy-protocol", "tcp", "ip"]
              },
              "version": {
                "description": "The version of the protocol.",
                "type": ["string", "integer"]
              },
              "sni": {
                "description": "The SNI in the client hello.",
                "type": "string"
              },
              "request-certificate": {
                "description": "Whether a certificate should be requested from the proxy.",
                "type": "boolean"
              },
              "verify-mode": {
                "description": "The server or client's OpenSSL verify mode against the proxy.",
                "type": "integer"
              },
              "proxy-provided-certificate": {
                "description": "Whether the proxy provided a cert in the handshake.",
                "type": "boolean"
              },
              "alpn-protocols": {
                "description": "The ALPN protocol list to advertise or expect.",
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "src-addr": {
                "description": "The source address and port in the PROXY header.",
                "type": "string"
              },
              "dst-addr": {
                "description": "The destination address and port in the PROXY header.",
                "type": "string"
              }
            }
          }
        },
        {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": false,
          "properties": {
            "stack": {
              "description": "A shorthand for common protocol stacks.",
              "type": "string",
              "enum": ["http", "https", "http2", "http3"]
            },
            "http": {
              "description": "Optional explicit HTTP layer override.",
              "oneOf": [
                {
                  "type": ["string", "integer"]
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "version": {
                      "type": ["string", "integer"]
                    }
                  }
                }
              ]
            },
            "tls": {
              "description": "Optional explicit TLS layer override.",
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "sni": {
                  "type": "string"
                },
                "request-certificate": {
                  "type": "boolean"
                },
                "verify-mode": {
                  "type": "integer"
                },
                "proxy-provided-certificate": {
                  "type": "boolean"
                },
                "alpn-protocols": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "proxy-protocol": {
              "description": "Optional PROXY protocol configuration.",
              "oneOf": [
                {
                  "type": ["string", "integer"],
                  "enum": ["1", "2", 1, 2]
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "version": {
                      "type": ["string", "integer"],
                      "enum": ["1", "2", 1, 2]
                    },
                    "src-addr": {
                      "type": "string"
                    },
                    "dst-addr": {
                      "type": "string"
                    }
                  }
                }
              ]
            },
            "tcp": {
              "description": "Optional explicit TCP layer override.",
              "type": "object",
              "additionalProperties": false
            },
            "ip": {
              "description": "Optional explicit IP layer override.",
              "type": "object",
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "header-fields": {
      "description": "HTTP header fields.",
      "type": "object",
      "required": ["fields"],
      "properties": {
        "encoding": {
          "description": "Encoding applied to field values.",
          "$ref": "#/definitions/encoding"
        },
        "fields": {
          "description": "The field name and value pairs.",
          "type": "array",
          "items": {
            "description": "HTTP field or verification rule.",
            "type": "array",
            "minItems": 2,
            "maxItems": 3,
            "items": [
              {
                "description": "Name of the field.",
                "type": "string"
              }, {
                "description": "Value of the field or an inline verification rule.",
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  {
                    "type": "object",
                    "properties": {
                      "value": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        ]
                      },
                      "as": {
                        "type": "string"
                      },
                      "not": {
                        "type": "string"
                      },
                      "case": {
                        "type": "string"
                      }
                    }
                  }
                ]
              }, {
                "description": "Legacy inline verification directive.",
                "type": "string"
              }
            ]
          }
        },
        "set-cookie-verifications": {
          "description": "Verification rules for Set-Cookie field lines.",
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "value": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    ]
                  },
                  "as": {
                    "type": "string"
                  },
                  "not": {
                    "type": "string"
                  },
                  "case": {
                    "type": "string"
                  }
                }
              }
            ]
          }
        }
      }
    },
    "request": {
      "title": "request",
      "description": "HTTP request.",
      "type": "object",
      "required": [ "method", "url" ],
      "properties": {
        "version": {
          "description": "HTTP version",
          "type": "string",
          "enum": ["0.9", "1.0", "1.1", "2", "3"]
        },
        "http2": {
          "description": "A description of the HTTP/2 properties",
          "type": "object",
          "required": [ "stream-id" ],
          "properties": {
            "stream-id": {
              "description": "The HTTP/2 stream identifier.",
              "type": "integer"
            },
            "priority": {
              "description": "A description of the HTTP/2 properties",
              "type": "object",
              "required": [ "stream-dependency", "weight" ],
              "properties": {
                "stream-dependency": {
                  "description": "The stream this stream depends upon.",
                  "type": "integer"
                },
                "weight": {
                  "description": "The priority weight assigned to the stream dependency.",
                  "type": "integer"
                }
              }
            }
          }
        },
        "scheme": {
          "description": "HTTP scheme (request).",
          "type": "string"
        },
        "method": {
          "description": "HTTP method (request)",
          "type": "string"
        },
        "url": {
          "description": "URL path, anchor, and parameters.",
          "type": "string"
        },
        "content": {
          "description": "Payload for this request",
          "$ref": "#/definitions/content"
        },
        "headers": {
          "description": "HTTP header fields.",
          "$ref": "#/definitions/header-fields"
        },
        "protocol": {
          "description": "The network protocol description of the connection.",
          "$ref": "#/definitions/protocol"
        }
      }
    },
    "response": {
      "title": "response",
      "description": "HTTP response.",
      "type": "object",
      "allOf": [
        {
          "if": {
            "properties": {
              "on_connect": {
                "enum": ["refuse", "reset"]
              }
            },
            "required": ["on_connect"]
          },
          "then": {},
          "else": {
            "required": ["status"]
          }
        }
      ],
      "properties": {
        "on_connect": {
          "description": "Connection action to take after reading the request.",
          "type": "string",
          "enum": ["accept", "refuse", "reset"]
        },
        "version": {
          "description": "HTTP version",
          "type": "string",
          "enum": ["0.9", "1.0", "1.1", "2", "3"]
        },
        "status": {
          "description": "Status code.",
          "type": "number"
        },
        "reason": {
          "description": "Reason phrase.",
          "type": "string"
        },
        "content": {
          "description": "HTTP Payload",
          "$ref": "#/definitions/content"
        },
        "headers": {
          "description": "HTTP header fields.",
          "$ref": "#/definitions/header-fields"
        }
      }
    }
  }
}
